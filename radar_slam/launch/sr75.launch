<launch>

  <param name="use_sim_time" value="true"/>

  <node pkg="radar_slam" type="sr75" name="sr75" output="screen">
    <param name="rcs_thresh" value="20"/>
    <param name="mad_thresh" value="2.5"/>
    <param name="min_pts" value="3"/>
    <param name="cos_min" value="0.1"/>
    <param name="dbscan_radius" value="2.5"/>
    <param name="dbscan_min_points" value="2"/>
    <param name="dbscan_min_cluster_size" value="5"/>
    <param name="vertical_deg" value="3.2"/>
    <param name="level_deg" value="1.6"/>
  </node>

  <node pkg="radar_slam" type="radarslam" name="slam" output="screen">
    <rosparam command="load" file="$(find radar_slam)/config/radar_slam.yaml"/>
    <remap from="/radarslam_input/PointCloud2" to="/RadarCombined"/>
  </node>

  <node pkg="tf2_ros" type="static_transform_publisher" name="odom_map_broadcaster" args="0 0 0 0 0 0 1 map odom" />  
  <node pkg="tf2_ros" type="static_transform_publisher" name="sr75_base_broadcaster" args="0 0 0 0 0 0 1 base_footprint sr75" />  
</launch>
