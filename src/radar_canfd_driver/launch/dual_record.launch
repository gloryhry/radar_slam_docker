<?xml version="1.0"?>
<launch>
  <!-- ================================================================== -->
  <!-- Dual ARS620 + Hipnuc IMU + rosbag record                          -->
  <!-- Usage: ./dual_record.sh [bag_name_prefix]                          -->
  <!-- ================================================================== -->

  <arg name="bag_name" default="dual_radar_imu" doc="Output bag name"/>
  <arg name="bag_dir"  default="/home/ctrr540_ws/radar_datasets" doc="Output directory"/>

  <param name="use_sim_time" value="false"/>

  <!-- Dual ARS620 (CH0=front, CH1=rear) -->
  <include file="$(find radar_canfd_driver)/launch/radar_canfd.launch"/>

  <!-- Hipnuc IMU -->
  <include file="$(find hipnuc_imu)/launch/imu_rviz.launch"/>

  <!-- Record all topics -->
  <node pkg="rosbag" type="record" name="record_all"
        args="record -O $(arg bag_dir)/$(arg bag_name) -a"
        output="screen"/>
</launch>
